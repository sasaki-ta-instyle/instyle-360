# 開発用。本番値は ConoHa の /var/www/_shared/apps/app-instyle-360.env で管理する。

# Postgres 接続文字列。ローカル開発は Docker か brew services の Postgres でOK。
# 例: postgresql://instyle360:password@localhost:5432/instyle360
DATABASE_URL=

# NextAuth v5
# 32 byte 以上のランダム文字列。openssl rand -base64 48 で生成。
AUTH_SECRET=
# basePath を含めた URL。ローカルなら http://localhost:3009/instyle-360
AUTH_URL=http://localhost:3009/instyle-360

# Resend
RESEND_API_KEY=
# 送信元。Resend 側で instyle.group の DNS を認証済みなのでサブアドレスでOK。
MAIL_FROM="instyle 360 <noreply@instyle.group>"

# 匿名性のしきい値（n 未満は平均を非表示にする）
ANONYMITY_MIN_RESPONSES=3
